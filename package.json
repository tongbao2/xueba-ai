{
  "name": "xuebadi-ai",
  "version": "1.0.0",
  "description": "学霸帝AI - Local Small Model AI Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg --x64"
  },
  "build": {
    "appId": "com.xuebadi.ai",
    "productName": "学霸帝AI",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "学霸帝AI 安装程序",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "extraResources": [
      {
        "from": "lib",
        "to": "lib",
        "filter": ["**/*"]
      },
      {
        "from": "bin",
        "to": "bin",
        "filter": ["**/*"]
      },
      {
        "from": "ocr-helper",
        "to": "ocr-helper",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {}
}
